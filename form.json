{
  "title": "Cargo Tank Inspection Form",
  "description": "Inspections and tests are to be performed on the Motor Vehicle Cargo Tank on the first Wednesday of each month.",
  "logo": "data:image/png;base64,",
  "pages": [
    {
      "name": "Page 1",
      "title": "Vehicle Info",
      "description": "Enter the DOT info",
      "elements": [
        {
          "type": "text",
          "name": "Technician Name",
          "title": "Inspected by:",
          "isRequired": true,
          "autocomplete": "name",
          "placeholder": "Enter your name",
          "dataList": [
            "Joward ",
            "John ",
            "Jason ",
            "Jimble ",
            "Jib",
            "Jam",
            "Jeffs",
            ""
          ]
        },
        {
          "type": "text",
          "name": "Date Time",
          "startWithNewLine": false,
          "title": "Inspection Date",
          "isRequired": true,
          "inputType": "date"
        },
        {
          "type": "radiogroup",
          "name": "Vehicle Type",
          "title": "Vehicle Type",
          "isRequired": true,
          "choices": [
            {
              "value": "Item 1",
              "text": "Bobtail"
            },
            {
              "value": "Item 4",
              "text": "Service"
            },
            {
              "value": "Item 3",
              "text": "Cylinder"
            }
          ]
        },
        {
          "type": "checkbox",
          "name": "Vehicle ID Bobtail",
          "visibleIf": "{Vehicle Type} = 'Item 1'",
          "startWithNewLine": false,
          "title": "Vehicle ID",
          "isRequired": true,
          "fieldMapping": [
            "bEquipmentID"
          ],
          "choices": [
            {
              "value": "Item 1",
              "text": "CE101NQL"
            },
            {
              "value": "Item 2",
              "text": "CE202NQL"
            },
            {
              "value": "Item 3",
              "text": "CE303NQL"
            },
            {
              "value": "Item 4",
              "text": "CE404NQL"
            }
          ]
        },
        {
          "type": "checkbox",
          "name": "Vehicle ID Service",
          "visibleIf": "{Vehicle Type} = 'Item 4'",
          "startWithNewLine": false,
          "title": "Vehicle ID",
          "isRequired": true,
          "fieldMapping": [
            "bEquipmentID"
          ],
          "choices": [
            {
              "value": "Item 1",
              "text": "SV007"
            },
            {
              "value": "Item 2",
              "text": "SV008"
            },
            {
              "value": "Item 3",
              "text": "SV009"
            },
            {
              "value": "Item 4",
              "text": "SV010"
            }
          ]
        },
        {
          "type": "paneldynamic",
          "name": "Piping System",
          "startWithNewLine": false,
          "title": "Piping System",
          "description": "Carefully examine each component of the system visually looking for any signs of leakage.",
          "isRequired": true,
          "templateElements": [
            {
              "type": "boolean",
              "name": "Pump",
              "title": "Pump",
              "isRequired": true,
              "labelTrue": "Pass",
              "labelFalse": "Fail",
              "valueTrue": "Pass",
              "valueFalse": "Fail",
              "swapOrder": true
            },
            {
              "type": "text",
              "name": "Pump Failure",
              "visibleIf": "{Piping System[0].Pump} = 'Fail'",
              "startWithNewLine": false,
              "title": "Failure Comments",
              "isRequired": true,
              "requiredIf": "{Piping System[0].Pump} = 'Fail'"
            },
            {
              "type": "boolean",
              "name": "Valve",
              "title": "Valve",
              "isRequired": true,
              "labelTrue": "Pass",
              "labelFalse": "Fail",
              "swapOrder": true
            },
            {
              "type": "text",
              "name": "question6",
              "visibleIf": "{Piping System[0].Valve} = false",
              "startWithNewLine": false,
              "title": "Failure Comments",
              "isRequired": true,
              "requiredIf": "{Piping System[0].Valve} = false"
            }
          ],
          "allowAddPanel": false,
          "allowRemovePanel": false,
          "panelCount": 1,
          "minPanelCount": 1,
          "maxPanelCount": 1,
          "tabAlign": "left"
        },
        {
          "type": "signaturepad",
          "name": "Signature",
          "title": "Inspector Signature",
          "description": "I certify all information recorded is true and accurate",
          "isRequired": true,
          "signatureWidth": 800,
          "signatureHeight": 300
        }
      ]
    }
  ]
}
